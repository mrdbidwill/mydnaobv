APP_NAME=myDNAobv
ENV=development
SECRET_KEY=change-me
DATABASE_URL=postgresql+psycopg://mydnaobv:password@localhost:5432/mydnaobv
# iNaturalist
INAT_BASE_URL=https://api.inaturalist.org/v1
# Use iNaturalist field ID 2330 for "DNA Barcode ITS".
# Do NOT use similarly named "DNA Barcode ITS:" (with colon), which is a different field.
INAT_DNA_FIELD_ID=2330
INAT_DNA_FIELD_NAME=DNA Barcode ITS
INAT_TAXON_ID=47170
# Optional default project slug/id used by admin county seeding.
INAT_DEFAULT_PROJECT_ID=
# County sync sources (comma/newline separated): query all and de-duplicate by observation ID.
INAT_COUNTY_PROJECT_IDS=124358,184305,132913,251751
CACHE_TTL_HOURS=24
MAX_OBSERVATIONS=500
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me
EXPORT_USERNAME=
EXPORT_PASSWORD=
# Optional preferred format for multiple export operators.
# Example:
# EXPORT_OPERATORS_JSON=[{"username":"ams_alice","password":"strong-pass-1"},{"username":"ams_bob","password":"strong-pass-2"}]
EXPORT_OPERATORS_JSON=

# PDF exports (KVM4 staged throughput profile; iNaturalist guardrails unchanged)
ENABLE_PDF_EXPORTS=false
EXPORT_STORAGE_DIR=/tmp/mydnaobv_exports
EXPORT_RETENTION_HOURS=48
EXPORT_RUN_TIMEOUT_SECONDS=90
EXPORT_PART_SIZE=100
EXPORT_DOWNLOAD_CHUNK_SIZE=8
EXPORT_DOWNLOAD_BYTE_BUDGET_MB=64
EXPORT_INCLUDE_ALL_PHOTOS=false
EXPORT_MAX_PHOTOS_PER_OBSERVATION=1
EXPORT_SORT_TAXON_SOURCE=observation
EXPORT_REQUEST_INTERVAL_SECONDS=2.0
EXPORT_MAX_API_REQUESTS_PER_DAY=6000
EXPORT_MAX_MEDIA_MB_PER_HOUR=3072
EXPORT_MAX_MEDIA_MB_PER_DAY=15360
EXPORT_XS_MAX_ITEMS=50
EXPORT_S_MAX_ITEMS=200
EXPORT_M_MAX_ITEMS=500
EXPORT_XS_CADENCE_MINUTES=2
EXPORT_S_CADENCE_MINUTES=4
EXPORT_M_CADENCE_MINUTES=8
EXPORT_L_CADENCE_MINUTES=20
EXPORT_L_WINDOW_START_HOUR=0
EXPORT_L_WINDOW_END_HOUR=12
EXPORT_ZIP_ONLY_PART_THRESHOLD=4
EXPORT_ALLOWED_LICENSES=cc0,cc-by,cc-by-sa,cc-by-nc,cc-by-nc-sa
EXPORT_ALLOW_UNLICENSED=false
EXPORT_PUBLISH_ENABLED=false
# publish backend: filesystem or s3 (Cloudflare R2 uses s3)
EXPORT_PUBLISH_BACKEND=filesystem
EXPORT_PUBLISH_DIR=/tmp/mydnaobv_published
EXPORT_PUBLISH_BASE_URL=
EXPORT_PUBLISH_BUCKET=
EXPORT_PUBLISH_PREFIX=
EXPORT_PUBLISH_S3_ENDPOINT=
EXPORT_PUBLISH_S3_REGION=auto
EXPORT_PUBLISH_S3_ACCESS_KEY_ID=
EXPORT_PUBLISH_S3_SECRET_ACCESS_KEY=
EXPORT_PUBLIC_DOWNLOADS_ENABLED=false
PUBLIC_REFRESH_INTERVAL_DAYS=7
# Public homepage state filter allowlist (comma-separated state codes; use ALL for all states)
PUBLIC_STATE_CODES=AL
ENABLE_DATA_CATALOG=true
CATALOG_PAGE_SIZE=50
CATALOG_SYNC_MAX_PAGES=2000
ADSENSE_ENABLED=false
# Example: ca-pub-1234567890123456
ADSENSE_CLIENT_ID=
# Optional fixed banner slot. Leave blank if using Auto Ads only.
ADSENSE_BANNER_SLOT=
