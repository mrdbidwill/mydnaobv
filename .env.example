APP_NAME=myDNAobv
ENV=development
SECRET_KEY=change-me
DATABASE_URL=postgresql+psycopg://mydnaobv:password@localhost:5432/mydnaobv
# iNaturalist
INAT_BASE_URL=https://api.inaturalist.org/v1
# Use iNaturalist field ID 2330 for "DNA Barcode ITS".
# Do NOT use similarly named "DNA Barcode ITS:" (with colon), which is a different field.
INAT_DNA_FIELD_ID=2330
INAT_DNA_FIELD_NAME=DNA Barcode ITS
INAT_TAXON_ID=47170
# Optional default project slug/id used by admin county seeding.
INAT_DEFAULT_PROJECT_ID=
# County sync sources (comma/newline separated): query all and de-duplicate by observation ID.
INAT_COUNTY_PROJECT_IDS=124358,184305,132913,251751
CACHE_TTL_HOURS=24
MAX_OBSERVATIONS=500
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me
EXPORT_USERNAME=
EXPORT_PASSWORD=
# Optional preferred format for multiple export operators.
# Example:
# EXPORT_OPERATORS_JSON=[{"username":"ams_alice","password":"strong-pass-1"},{"username":"ams_bob","password":"strong-pass-2"}]
EXPORT_OPERATORS_JSON=

# PDF exports (KVM4 upgraded throughput profile; iNaturalist guardrails unchanged)
ENABLE_PDF_EXPORTS=true
EXPORT_STORAGE_DIR=/tmp/mydnaobv_exports
EXPORT_RETENTION_HOURS=48
EXPORT_RUN_TIMEOUT_SECONDS=300
EXPORT_PART_SIZE=220
EXPORT_MAX_PART_SIZE_SINGLE_PHOTO=320
EXPORT_MAX_PART_SIZE_ALL_PHOTOS=180
EXPORT_SYNC_MAX_CONCURRENT=1
EXPORT_SYNC_SLOT_RETRY_SECONDS=120
EXPORT_SYNC_BACKOFF_MAX_SECONDS=21600
EXPORT_SYNC_BACKOFF_JITTER_RATIO=0.15
# Product types that may continue export from cached observations when sync is delayed/throttled.
EXPORT_SYNC_DEFER_TO_CACHE_PRODUCTS=project
# Cooldown before auto-refresh retries a force-sync after a deferred-to-cache export.
EXPORT_SYNC_DEFER_RETRY_MINUTES=360
# Optional temporary priority lane for specific list IDs (comma-separated).
# When set, pickable jobs for these list IDs are selected before other lists.
EXPORT_PRIORITY_LIST_IDS=
# Storage pressure guardrails:
# - if free disk drops below threshold, auto-refresh enqueue is skipped
# - active queued/waiting jobs are paused to waiting_quota until retry window
EXPORT_STORAGE_PRESSURE_MIN_FREE_GB=8
EXPORT_STORAGE_PRESSURE_RETRY_SECONDS=600
EXPORT_DOWNLOAD_CHUNK_SIZE=16
EXPORT_DOWNLOAD_BYTE_BUDGET_MB=256
EXPORT_IMAGE_CACHE_ENABLED=true
EXPORT_IMAGE_CACHE_TTL_DAYS=14
EXPORT_IMAGE_CACHE_RETENTION_DAYS=45
EXPORT_IMAGE_CACHE_PRUNE_INTERVAL_HOURS=24
EXPORT_IMAGE_CACHE_MAX_PRUNE_FILES=500
EXPORT_INCLUDE_ALL_PHOTOS=false
EXPORT_MAX_PHOTOS_PER_OBSERVATION=1
EXPORT_SORT_TAXON_SOURCE=observation
EXPORT_REQUEST_INTERVAL_SECONDS=0.5
EXPORT_MAX_API_REQUESTS_PER_DAY=6000
EXPORT_MAX_MEDIA_MB_PER_HOUR=3072
EXPORT_MAX_MEDIA_MB_PER_DAY=15360
EXPORT_XS_MAX_ITEMS=50
EXPORT_S_MAX_ITEMS=200
EXPORT_M_MAX_ITEMS=500
EXPORT_XS_CADENCE_MINUTES=1
EXPORT_S_CADENCE_MINUTES=2
EXPORT_M_CADENCE_MINUTES=4
EXPORT_L_CADENCE_MINUTES=8
EXPORT_L_WINDOW_START_HOUR=0
EXPORT_L_WINDOW_END_HOUR=24
EXPORT_ZIP_ONLY_PART_THRESHOLD=10
# Split very large export ZIPs into easier-to-download parts (0 disables chunk files).
EXPORT_ZIP_CHUNK_SIZE_MB=1024
EXPORT_ALLOWED_LICENSES=cc0,cc-by,cc-by-sa,cc-by-nc,cc-by-nc-sa
EXPORT_ALLOW_UNLICENSED=false
EXPORT_PUBLISH_ENABLED=false
# publish backend: filesystem or s3 (Cloudflare R2 uses s3)
EXPORT_PUBLISH_BACKEND=filesystem
EXPORT_PUBLISH_DIR=/tmp/mydnaobv_published
EXPORT_PUBLISH_BASE_URL=
EXPORT_PUBLISH_BUCKET=
EXPORT_PUBLISH_PREFIX=
EXPORT_PUBLISH_S3_ENDPOINT=
EXPORT_PUBLISH_S3_REGION=auto
EXPORT_PUBLISH_S3_ACCESS_KEY_ID=
EXPORT_PUBLISH_S3_SECRET_ACCESS_KEY=
# Publish queue throughput per worker run (publish now runs outside finalize path).
EXPORT_PUBLISH_JOBS_PER_RUN=3
EXPORT_PUBLIC_DOWNLOADS_ENABLED=false
PUBLIC_REFRESH_INTERVAL_DAYS=7
PUBLIC_AUTO_REFRESH_ENQUEUE_PER_RUN=2
# Public homepage state filter allowlist (comma-separated state codes; use ALL for all states)
PUBLIC_STATE_CODES=AL
ENABLE_DATA_CATALOG=true
CATALOG_PAGE_SIZE=50
CATALOG_SYNC_MAX_PAGES=2000
ADSENSE_ENABLED=false
ADSENSE_CLIENT_ID=ca-pub-8323362126637830
# Optional fixed banner slot (not required for basic Auto Ads setup).
ADSENSE_BANNER_SLOT=
